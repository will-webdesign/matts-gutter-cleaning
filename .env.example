# ---------------------------------------------------------------------------
# Matt's Gutter Cleaning — environment variables
# Copy this file to ".env" and fill in real values. ".env" is gitignored.
# ---------------------------------------------------------------------------

# Public site URL (used for OG tags, sitemap, email links). No trailing slash.
NEXT_PUBLIC_SITE_URL="https://www.mattsguttercleaning.co.uk"

# --- Database -------------------------------------------------------------
# Local dev: SQLite (default, zero setup).
DATABASE_URL="file:./dev.db"
# Production (Supabase/Postgres): change schema.prisma datasource provider to
# "postgresql" and use the pooled connection string, e.g.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# --- Admin auth -----------------------------------------------------------
# Long random string used to sign admin sessions (e.g. `openssl rand -base64 32`).
AUTH_SECRET="please-generate-a-long-random-secret"
# The password Matt uses to log in at /admin.
ADMIN_PASSWORD="change-this-password"

# --- Email (Resend) -------------------------------------------------------
# Without these, emails are logged to the console instead of sent (dev-friendly).
RESEND_API_KEY=""
EMAIL_FROM="Matt's Gutter Cleaning <bookings@yourdomain.co.uk>"

# --- Cron (reminders) -----------------------------------------------------
# Secret for the daily /api/reminders job (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=""

# --- SMS (future, Twilio) -------------------------------------------------
# Placeholders so SMS can be added later without restructuring (see lib/email.ts pattern).
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
